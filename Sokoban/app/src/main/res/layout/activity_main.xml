<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color">

    <!-- Main menu screen -->
    <LinearLayout
        android:id="@+id/mainMenuLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="52sp"
            android:textColor="@color/title_color"
            android:textStyle="bold"
            android:layout_marginTop="120dp"
            android:layout_marginBottom="80dp"/>

        <Button
            android:id="@+id/btnStartGame"
            android:layout_width="220dp"
            android:layout_height="56dp"
            android:text="@string/start_game"
            android:textSize="18sp"
            android:textColor="@color/button_text"
            android:backgroundTint="@color/button_primary"
            android:layout_marginBottom="20dp"/>

        <Button
            android:id="@+id/btnLevelSelect"
            android:layout_width="220dp"
            android:layout_height="56dp"
            android:text="@string/level_select"
            android:textSize="18sp"
            android:textColor="@color/button_primary"
            android:backgroundTint="@color/white"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginBottom="20dp"/>

        <Button
            android:id="@+id/btnLevelEditor"
            android:layout_width="220dp"
            android:layout_height="56dp"
            android:text="@string/level_editor"
            android:textSize="18sp"
            android:textColor="@color/button_primary"
            android:backgroundTint="@color/white"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

    </LinearLayout>

    <!-- Level select screen -->
    <LinearLayout
        android:id="@+id/levelSelectLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/level_select"
            android:textSize="32sp"
            android:textColor="@color/title_color"
            android:textStyle="bold"
            android:layout_marginTop="48dp"
            android:layout_marginBottom="32dp"/>

        <GridLayout
            android:id="@+id/levelGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="4"
            android:rowCount="4"
            android:layout_gravity="center_horizontal"
            android:useDefaultMargins="true"/>

        <Button
            android:id="@+id/btnBackToMenu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="返回主菜单"
            android:textColor="@color/text_secondary"
            android:backgroundTint="@color/background_color"
            android:layout_marginTop="32dp"/>

    </LinearLayout>

    <!-- Game screen -->
    <LinearLayout
        android:id="@+id/gameLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <!-- Top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="4dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_revert"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="返回"
                app:tint="@color/title_color"/>

            <TextView
                android:id="@+id/tvLevel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/title_color"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"/>

            <TextView
                android:id="@+id/tvMoves"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="16sp"/>

        </LinearLayout>

        <!-- Game view -->
        <com.sokoban.game.GameView
            android:id="@+id/gameView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- Bottom buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="4dp"
            android:paddingBottom="8dp">

            <Button
                android:id="@+id/btnRestart"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="@string/restart"
                android:textSize="14sp"
                android:textColor="@color/button_text"
                android:backgroundTint="@color/button_primary"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Win dialog overlay -->
    <LinearLayout
        android:id="@+id/winOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#B3FFFFFF"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/congratulations"
            android:textSize="40sp"
            android:textColor="@color/button_primary"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/tvStars"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="36sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvWinStats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnNextLevel"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:text="@string/next_level"
            android:textSize="18sp"
            android:textColor="@color/button_text"
            android:backgroundTint="@color/button_primary"/>

    </LinearLayout>

    <!-- Level editor screen -->
    <LinearLayout
        android:id="@+id/editorLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/background_color"
        android:visibility="gone">

        <!-- Top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="4dp">

            <ImageButton
                android:id="@+id/btnEditorBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_revert"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="返回"
                app:tint="@color/title_color"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/level_editor"
                android:textColor="@color/title_color"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"/>

            <Button
                android:id="@+id/btnEditorClear"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/clear"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:backgroundTint="@color/background_color"/>

        </LinearLayout>

        <!-- Editor grid -->
        <com.sokoban.game.LevelEditorView
            android:id="@+id/editorView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- Cell type palette -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingVertical="4dp">

            <LinearLayout
                android:id="@+id/paletteLayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="8dp"/>

        </HorizontalScrollView>

        <!-- Bottom action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="4dp"
            android:paddingBottom="8dp">

            <Button
                android:id="@+id/btnEditorTest"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="@string/test"
                android:textSize="14sp"
                android:textColor="@color/button_text"
                android:backgroundTint="@color/button_primary"
                android:layout_marginHorizontal="6dp"/>

            <Button
                android:id="@+id/btnEditorSave"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="@string/save"
                android:textSize="14sp"
                android:textColor="@color/button_text"
                android:backgroundTint="@color/button_primary"
                android:layout_marginHorizontal="6dp"/>

            <Button
                android:id="@+id/btnEditorExport"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="@string/export"
                android:textSize="14sp"
                android:textColor="@color/button_text"
                android:backgroundTint="@color/button_primary"
                android:layout_marginHorizontal="6dp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
